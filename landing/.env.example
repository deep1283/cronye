# Optional: landing download link (MVP supports macOS Apple Silicon).
# If unset, the landing page defaults to /api/download/macos.
NEXT_PUBLIC_DOWNLOAD_URL_MAC=/api/download/macos

# Optional support flow.
# Default support link points to /api/support/checkout (one-click redirect to Dodo).
# You can override with an external URL by setting NEXT_PUBLIC_SUPPORT_URL.
NEXT_PUBLIC_SUPPORT_URL=/api/support/checkout

# Optional support checkout via Dodo API.
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_API_KEY=dp_test_xxx
DODO_PRODUCT_ID=pdt_xxx
DODO_RETURN_URL_BASE=http://localhost:3000
# Optional domain for generated support checkout customer emails.
SUPPORT_CHECKOUT_EMAIL_DOMAIN=cronye.app

# Server-side private release proxy (required if release repo is private).
GITHUB_RELEASE_TOKEN=github_pat_xxx
GITHUB_RELEASE_OWNER=deep1283
GITHUB_RELEASE_REPO=cronye
GITHUB_RELEASE_TAG=v0.1.6
GITHUB_RELEASE_ASSET_MACOS=cronye-macos.dmg
